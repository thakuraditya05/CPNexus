{
  "manifest_version": 3,
  "name": "CP & Tracker Dashboard",
  "version": "1.0.0",
  "description": "The ultimate Competitive Programming dashboard with widgets, reminders, calendar, and MANIT updates.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "sidePanel",
    "identity",
    "identity.email",
    "declarativeNetRequest", 
    "declarativeNetRequestWithHostAccess"

  ],
  "host_permissions": [
    "https://clist.by/*",
    "https://leetcode.com/*",
    "https://codeforces.com/*",
    "https://*.manit.ac.in/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Open CP Side Panel"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}